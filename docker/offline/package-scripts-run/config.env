# OpsFactory deployment configuration
# Edit this file before running start.sh

# Ports are FIXED in host network mode (5173 webapp, 3000 gateway, 8092 knowledge, 8096 operation-intelligence).
# To change ports you must rebuild the image with different service configs.

# Container name
CONTAINER_NAME=opsfactory

# Docker image
IMAGE_TAG=opsfactory:offline-20260603-linux-amd64

# Data directory on host (relative to package root)
DATA_DIR=./data

# Restart policy
RESTART_POLICY=unless-stopped
